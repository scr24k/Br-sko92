-- ─────────────────────────────────────────────
--  HELPER: perform the insta-reset action
-- ─────────────────────────────────────────────
local function DoInstaReset()
    local character = LocalPlayer.Character
    if not character then return end

    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end

    -- Freeze player
    humanoid.WalkSpeed  = 0
    humanoid.JumpPower  = 0
    humanoid.AutoRotate = false
    InstaResetButton.Text = "DONE"

    -- Teleport to CraftingMachine
    local craftPos = workspace:FindFirstChild("CraftingMachine")
    if craftPos then
        local vfxPart = craftPos:FindFirstChild("VFX")
        if vfxPart then
            local secret = vfxPart:FindFirstChild("Secret")
            if secret then
                local soundPart = secret:FindFirstChild("SoundPart")
                if soundPart then
                    character:PivotTo(CFrame.new(soundPart.Position))
                end
            end
        end
    end

    -- Restore after short delay
    task.delay(1.5, function()
        if humanoid and humanoid.Parent then
            humanoid.WalkSpeed  = 16
            humanoid.JumpPower  = 50
            humanoid.AutoRotate = true
        end
        InstaResetButton.Text = "INSTA RESET"
        StatusLabel.Text = "ACTIVE"
    end)
end

-- ─────────────────────────────────────────────
--  MINIMIZE / RESTORE
-- ─────────────────────────────────────────────
local function SetMinimized(state)
    isMinimized = state
    local targetSizeY = state and 42 or 150
    TweenService:Create(MainFrame, TWEEN_INFO_FAST, {
        Size = UDim2.new(0, 230, 0, targetSizeY)
    }):Play()
    MainFrame.ClipsDescendants = true
    MinimizeButton.Text = state and "+" or "-"
end

-- ─────────────────────────────────────────────
--  SETTINGS PANEL  OPEN / CLOSE
-- ─────────────────────────────────────────────
local function SetSettingsPanel(open)
    settingsPanelOpen = open
    if open then
        SettingsPanel.Visible = true
        TweenService:Create(SettingsPanel, TWEEN_INFO_PANEL, {
            Size = UDim2.new(0, 230, 0, 100)
        }):Play()
    else
        local t = TweenService:Create(SettingsPanel, TWEEN_INFO_PANEL, {
            Size = UDim2.new(0, 230, 0, 0)
        })
        t:Play()
        t.Completed:Connect(function(state)
            if state == Enum.PlaybackState.Completed then
                SettingsPanel.Visible = false
            end
        end)
    end
end

-- ─────────────────────────────────────────────
--  TOGGLE: Reset on Balloon
-- ─────────────────────────────────────────────
local function SetToggle(value)
    resetOnBalloon = value
    if value then
        ToggleDot.BackgroundColor3   = ACCENT
        ToggleStateLabel.Text        = "ON"
        ToggleStateLabel.TextColor3  = ACCENT_SOFT
        ToggleDotStroke.Transparency = 0.4
    else
        ToggleDot.BackgroundColor3   = TOGGLE_OFF
        ToggleStateLabel.Text        = "OFF"
        ToggleStateLabel.TextColor3  = TEXT_OFF
        ToggleDotStroke.Transparency = 1
    end
end

