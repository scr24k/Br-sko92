-- ─────────────────────────────────────────────
--  DRAG LOGIC
-- ─────────────────────────────────────────────
MainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
    or input.UserInputType == Enum.UserInputType.Touch then
        isDragging    = true
        dragStartPos  = input.Position
        frameStartPos = MainFrame.Position
    end
end)

MainFrame.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
    or input.UserInputType == Enum.UserInputType.Touch then
        isDragging = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if not isDragging then return end
    if input.UserInputType ~= Enum.UserInputType.MouseMovement
    and input.UserInputType ~= Enum.UserInputType.Touch then return end

    local delta = input.Position - dragStartPos
    MainFrame.Position = UDim2.new(
        frameStartPos.X.Scale,
        frameStartPos.X.Offset + delta.X,
        frameStartPos.Y.Scale,
        frameStartPos.Y.Offset + delta.Y
    )
end)

-- ─────────────────────────────────────────────
--  BALLOON AUTO-RESET (when resetOnBalloon toggle is ON)
-- ─────────────────────────────────────────────
local function SetupBalloonDetect(character)
    if not character then return end
    character.DescendantAdded:Connect(function(desc)
        if not resetOnBalloon then return end
        -- Heuristic: if a "Balloon" tool or accessory is added, trigger reset
        if desc.Name:lower():find("balloon") then
            DoInstaReset()
        end
    end)
end

LocalPlayer.CharacterAdded:Connect(function(char)
    SetupBalloonDetect(char)
end)

if LocalPlayer.Character then
    SetupBalloonDetect(LocalPlayer.Character)
end

